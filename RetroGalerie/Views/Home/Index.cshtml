@model RetroGalerie.Models.HomeViewModel

<div class="container">
    <h1 class="display-4 text-center mb-5">RetroGalerie</h1>

    @{
        var totalJeux = Model.Consoles.Sum(c => c.GameCount);
    }

    <!-- Total général -->
    <div class="text-center mb-4">
        <h3>Total général : <span id="totalJeuxGlobal">@totalJeux</span> jeux</h3>
    </div>

    <!-- Jeux possédés ou en liste de souhaits -->
    <div class="text-center mb-4">
        <div class="btn-group" role="group">
            <button id="btnOwned" class="btn btn-success active">Jeux possédés</button>
            <button id="btnWishlist" class="btn btn-outline-secondary">Jeux souhaités</button>
        </div>
    </div>

    <!-- Tableau récap cliquable -->
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Console</th>
                <th class="text-end">Nombre de jeux</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var console in Model.Consoles)
            {
                var collapseId = $"collapse-{console.ConsoleName.Replace(" ", "")}";

                <!-- Ligne cliquable -->
                <tr class="console-toggle"
                    style="cursor:pointer"
                    data-console-name="@console.ConsoleName"
                    data-bs-toggle="collapse"
                    data-bs-target="#@collapseId"
                    data-target-id="@collapseId">

                    <td>@console.ConsoleName</td>

                    <td class="text-end">
                        <span class="badge bg-primary console-count">@console.GameCount</span>
                        <span class="arrow ms-2">&#9656;</span>
                    </td>
                </tr>

                <!-- Ligne contenant les cards -->
                <tr class="collapse" id="@collapseId">
                    <td colspan="2">
                        <div class="row mt-3">
                            @foreach (var game in console.Games)
                            {
                                <div class="col-md-3 mb-4 game-card"
                                     data-owned="@game.Owned"
                                     data-console="@console.ConsoleName">

                                    <div class="card h-100 shadow-sm">
                                        <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id">
                                            <img src="@game.CoverImageUrl"
                                                 class="card-img-top @(game.ConsoleName == "SNES" ? "card-img-snes" : "card-img-nes")"
                                                 alt="@game.Title" />
                                        </a>
                                        <div class="card-body text-center">
                                            <h5 class="card-title">@game.Title</h5>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Script -->
<script>
    document.addEventListener("DOMContentLoaded", function () {

        /* --- Gestion du style actif sur les consoles --- */
        const items = document.querySelectorAll(".console-toggle");

        items.forEach(item => {
            const collapseId = item.getAttribute("data-target-id");
            const collapseElement = document.getElementById(collapseId);

            collapseElement.addEventListener("show.bs.collapse", () => {
                item.classList.add("active-console");
            });

            collapseElement.addEventListener("hide.bs.collapse", () => {
                item.classList.remove("active-console");
            });
        });

        /* --- Filtrage Owned / Wishlist --- */
        const btnOwned = document.getElementById("btnOwned");
        const btnWishlist = document.getElementById("btnWishlist");
        const cards = document.querySelectorAll(".game-card");

        function updateFilter(showOwned) {
            cards.forEach(card => {
                const owned = card.getAttribute("data-owned") === "True";
                card.style.display = (owned === showOwned) ? "block" : "none";
            });
        }

        /* --- Mise à jour des compteurs --- */
        function updateCounts(showOwned) {
            const rows = document.querySelectorAll(".console-toggle");
            let total = 0;

            rows.forEach(row => {
                const consoleName = row.getAttribute("data-console-name");
                const countSpan = row.querySelector(".console-count");

                const consoleCards = document.querySelectorAll(
                    `.game-card[data-console='${consoleName}']`
                );

                let visibleCount = 0;

                consoleCards.forEach(card => {
                    const owned = card.getAttribute("data-owned") === "True";
                    if (owned === showOwned) visibleCount++;
                });

                countSpan.textContent = visibleCount;
                total += visibleCount;
            });

            document.getElementById("totalJeuxGlobal").textContent = total;
        }

        /* --- Initialisation : jeux possédés --- */
        updateFilter(true);
        updateCounts(true);

        /* --- Bouton "Jeux possédés" --- */
        btnOwned.addEventListener("click", () => {
            btnOwned.classList.add("active", "btn-success");
            btnOwned.classList.remove("btn-outline-secondary");

            btnWishlist.classList.remove("active", "btn-success");
            btnWishlist.classList.add("btn-outline-secondary");

            updateFilter(true);
            updateCounts(true);
        });

        /* --- Bouton "Jeux souhaités" --- */
        btnWishlist.addEventListener("click", () => {
            btnWishlist.classList.add("active", "btn-success");
            btnWishlist.classList.remove("btn-outline-secondary");

            btnOwned.classList.remove("active", "btn-success");
            btnOwned.classList.add("btn-outline-secondary");

            updateFilter(false);
            updateCounts(false);
        });
    });
</script>

<!-- Style -->
<style>
    table thead th {
        background-color: #4f6b5a !important;
        color: #f8f9fa !important;
        font-weight: bold;
        border-bottom: 2px solid #3d4f45;
    }

    .console-toggle {
        background-color: #1f2a24 !important;
        color: #f8f9fa !important;
    }

        .console-toggle:hover {
            background-color: #2c3a32 !important;
            color: #f8f9fa !important;
        }

    .active-console {
        background-color: #3d4f45 !important;
        font-weight: bold;
        color: #f8f9fa !important;
    }

        .active-console td,
        .active-console span {
            color: #f8f9fa !important;
        }

    .console-toggle .arrow {
        transition: transform 0.3s ease;
        color: #f8f9fa !important;
    }

    .active-console .arrow {
        transform: rotate(90deg);
    }
</style>
