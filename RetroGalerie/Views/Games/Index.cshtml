@model IEnumerable<RetroGalerie.Models.GameViewModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Liste des jeux</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["TitleSortParam"]">
                    @Html.DisplayNameFor(model => model.Title)
                    @if (ViewData["CurrentSort"]?.ToString() == "Title")
                    {
                        <span>↑</span>
                    }
                    @if (ViewData["CurrentSort"]?.ToString() == "title_desc")
                    {
                        <span>↓</span>
                    }
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParam"]">
                    @Html.DisplayNameFor(model => model.YearOfPublication)
                    @if (ViewData["CurrentSort"]?.ToString() == "Date")
                    {
                        <span>↑</span>
                    }
                    @if (ViewData["CurrentSort"]?.ToString() == "date_desc")
                    {
                        <span>↓</span>
                    }
                </a>
            </th>
@*             <th>
                @Html.DisplayNameFor(model => model.Description)
            </th> *@
            <th>
                @Html.DisplayNameFor(model => model.NumberOfPlayers)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Genre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Developer)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Publisher)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Region)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Language)
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["ConsoleSortParam"]">
                    Console
                    @if (ViewData["CurrentSort"]?.ToString() == "Console")
                    {
                        <span>↑</span>
                    }
                    @if (ViewData["CurrentSort"]?.ToString() == "console_desc")
                    {
                        <span>↓</span>
                    }
                </a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Title)</td>
                <td>@Html.DisplayFor(modelItem => item.YearOfPublication)</td>
@*                 <td>@Html.DisplayFor(modelItem => item.Description)</td> *@
                <td>@Html.DisplayFor(modelItem => item.NumberOfPlayers)</td>
                <td>@Html.DisplayFor(modelItem => item.Genre)</td>
                <td>@Html.DisplayFor(modelItem => item.Developer)</td>
                <td>@Html.DisplayFor(modelItem => item.Publisher)</td>
                <td>@Html.DisplayFor(modelItem => item.Region)</td>
                <td>@Html.DisplayFor(modelItem => item.Language)</td>
                <td>@Html.DisplayFor(modelItem => item.ConsoleName)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
