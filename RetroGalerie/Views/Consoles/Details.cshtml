@using RetroGalerie.Services
@model RetroGalerie.Models.ConsoleViewModel
@inject SharedLocalizationService Localizer

@{
    ViewData["Title"] = "Details";
}

<h1>@Localizer.Get("Details")</h1>

<div>

    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Localizer.Get("Name")
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt class="col-sm-2">
            @Localizer.Get("Manufacturer")
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Manufacturer)
        </dd>

        <dt class="col-sm-2">
            @Localizer.Get("ReleaseYear")
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ReleaseYear)
        </dd>
        <dt class="col-sm-2">
            @Localizer.Get("Description")
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>

        <!-- Bloc image -->
        <dt class="col-sm-2">
            @Localizer.Get("Logo_Image")
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Url.Content(Model.ImageUrl)" alt="@Model.Name"
                     class="img-fluid rounded shadow" style="max-height:200px;" />
            }
            else
            {
                <span class="text-muted">@Localizer.Get("No_Image")</span>
            }
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" class="btn btn-sm btn-warning" asp-route-id="@Model?.Id">@Localizer.Get("Edit")</a> |
    <a asp-action="Index" class="btn btn-secondary btn-sm">@Localizer.Get("Back_to_List")</a>
</div>
