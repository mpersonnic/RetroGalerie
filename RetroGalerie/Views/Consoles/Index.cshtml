@using RetroGalerie.Services
@model IEnumerable<RetroGalerie.Models.ConsoleViewModel>
@inject SharedLocalizationService Localizer

@{
    ViewData["Title"] = "Index";
    var currentSort = ViewData["CurrentSort"] as string;
}

<h1>Consoles</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>@Localizer.Get("Logo_Image")</th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]">
                    @Localizer.Get("Name")
                </a>
                @if (currentSort == "")
                {
                    <span>↑</span>
                }
                else if (currentSort == "name_desc")
                {
                    <span>↓</span>
                }
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["ManufacturerSortParm"]">
                    @Localizer.Get("Manufacturer")
                </a>
                @if (currentSort == "manufacturer")
                {
                    <span>↑</span>
                }
                else if (currentSort == "manufacturer_desc")
                {
                    <span>↓</span>
                }
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["YearSortParm"]">
                    @Localizer.Get("ReleaseYear")
                </a>
                @if (currentSort == "year")
                {
                    <span>↑</span>
                }
                else if (currentSort == "year_desc")
                {
                    <span>↓</span>
                }
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@Url.Content(item.ImageUrl)" alt="@item.Name"
                             class="img-thumbnail" style="max-height:80px;" />
                    }
                    else
                    {
                        <span class="text-muted">Pas d'image</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Manufacturer)</td>
                <td>@Html.DisplayFor(modelItem => item.ReleaseYear)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
