@using RetroGalerie.Services
@inject SharedLocalizationService Localizer

@model RetroGalerie.Models.ConsoleViewModel
@{
    ViewData["Title"] = "Create";
}

<h1>@Localizer.Get("Create")</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label">@Localizer.Get("Name")</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Manufacturer" class="control-label">@Localizer.Get("Manufacturer")</label>
                <input asp-for="Manufacturer" class="form-control" />
                <span asp-validation-for="Manufacturer" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ReleaseYear" class="control-label">@Localizer.Get("ReleaseYear")</label>
                <input asp-for="ReleaseYear" class="form-control" />
                <span asp-validation-for="ReleaseYear" class="text-danger"></span>
            </div>

            <!-- Champ upload -->
            <div class="form-group">
                <label asp-for="ImageFile" class="control-label">@Localizer.Get("Logo_Image")</label>
                <input asp-for="ImageFile" type="file" class="form-control" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label">@Localizer.Get("Description")</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="@Localizer.Get("Create")" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">@Localizer.Get("Back_to_List")</a>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
